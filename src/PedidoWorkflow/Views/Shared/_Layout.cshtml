<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pedido Workflow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="topbar">
            <div class="container app-nav">
                <a class="brand-mark" asp-controller="Home" asp-action="Index">
                    <span class="brand-dot"></span>
                    <span>
                        <strong>Pedido Workflow</strong>
                        <small>gestao operacional</small>
                    </span>
                </a>
                <nav class="nav-links">
                    <a asp-controller="Home" asp-action="Index">Dashboard</a>
                    <a asp-controller="Pedidos" asp-action="Index">Pedidos</a>
                    <a asp-controller="Pedidos" asp-action="Create">Novo Pedido</a>
                    <a asp-controller="Workflow" asp-action="Index">Workflow</a>
                </nav>
            </div>
        </header>

        <main class="container page-content">
            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="alert alert-success app-alert" role="alert">@successMessage</div>
            }

            @if (TempData["ErrorMessage"] is string errorMessage)
            {
                <div class="alert alert-danger app-alert" role="alert">@errorMessage</div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
